{
  "name": "map_project",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @map_project/db db:push",
    "db:studio": "turbo -F @map_project/db db:studio",
    "db:generate": "turbo -F @map_project/db db:generate",
    "db:migrate": "turbo -F @map_project/db db:migrate",
    "db:seed": "turbo run db:seed"
  },
  "dependencies": {
    "@map_project/env": "*",
    "@types/leaflet": "^1.9.21",
    "dotenv": "^17.2.2",
    "leaflet": "^1.9.4",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@map_project/config": "*",
    "@types/node": "^22.13.14",
    "turbo": "^2.8.12",
    "typescript": "^5"
  },
  "packageManager": "npm@10.9.4"
}