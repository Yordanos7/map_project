model RoadSign {
  id        String   @id
  objectid  Int
  signType  String   @map("sign_type")
  lat       Float
  long      Float
  remark    String?
  
  // PostGIS geometry column
  geom      Unsupported("geometry(Point, 4326)")?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("road_signs")
}

// -----------------------------------------------------
// DIVA-GIS Exact Shapefile Models (Ethiopia Specific)
// These models EXACTLY match the tables generated by shp2pgsql
// when importing DIVA-GIS shapefiles (like ETH_adm.zip or ETH_rds.zip).
// -----------------------------------------------------

model EthiopiaBoundary {
  // Primary key automatically generated by shp2pgsql
  gid       Int     @id @default(autoincrement())
  
  // Standard DIVA-GIS .dbf attributes for Ethiopian Administrative Boundaries
  id_0      Int?
  iso       String? @db.VarChar(254)
  name_0    String? @db.VarChar(254)
  id_1      Int?
  name_1    String? @db.VarChar(254)
  type_1    String? @db.VarChar(254)
  engtype_1 String? @db.VarChar(254)
  nl_name_1 String? @db.VarChar(254)
  varname_1 String? @db.VarChar(254)
  
  // Exact PostGIS spatial geography column formatting for boundaries
  geom      Unsupported("geometry(MultiPolygon, 4326)")?

  @@map("eth_adm1")
}

model EthiopiaRoad {
  // Primary key automatically generated by shp2pgsql
  gid         Int     @id @default(autoincrement())
  
  // Specific DIVA-GIS .dbf attributes for Ethiopian Roads inside this dataset
  med_descri  String? @db.VarChar(254)
  rtt_descri  String? @db.VarChar(254)
  f_code_des  String? @db.VarChar(10)
  iso         String? @db.VarChar(7)
  isocountry  String? @db.VarChar(54)
  
  // Exact PostGIS spatial geography column formatting for paths
  geom        Unsupported("geometry(MultiLineString, 4326)")?

  @@map("eth_roads")
}

model WorldBoundary {
  gid       Int     @id @default(autoincrement())
  admin     String? @db.VarChar(254)
  geom      Unsupported("geometry(MultiPolygon, 4326)")?

  @@map("world_boundaries")
}

// --------------------------------------------------------
// Ethiopian Population Density Grid (from geodata .grd raster)
// Each row = one 3km² pixel cell converted to a PostGIS Point.
// --------------------------------------------------------
model EthiopiaPopulation {
  gid        Int     @id @default(autoincrement())
  population Int
  lon        Float
  lat        Float
  geom       Unsupported("geometry(Point, 4326)")?

  @@map("eth_population")
}

// --------------------------------------------------------
// Ethiopian Populated Places (Cities, Towns, Villages etc)
// --------------------------------------------------------
model EthiopiaSettlement {
  gid        Int     @id @default(autoincrement())
  name       String? @db.VarChar(80)
  name_en    String? @db.VarChar(80)
  place      String? @db.VarChar(80)
  landuse    String? @db.VarChar(80)
  population String? @db.VarChar(80)
  is_in      String? @db.VarChar(80)
  source     String? @db.VarChar(97)
  osm_id     Float?
  osm_type   String? @db.VarChar(80)
  geom       Unsupported("geometry(Point, 4326)")?

  @@map("eth_settlements")
}

// --------------------------------------------------------
// Ethiopian Health Facilities (Hospitals, Clinics, etc)
// --------------------------------------------------------
model EthiopiaHealth {
  gid        Int     @id @default(autoincrement())
  name       String? @db.VarChar(127)
  name_en    String? @db.VarChar(101)
  amenity    String? @db.VarChar(80)
  building   String? @db.VarChar(80)
  healthcare String? @db.VarChar(80)
  healthca_1 String? @db.VarChar(254)
  operator_t String? @db.VarChar(80)
  capacity_p String? @db.VarChar(80)
  addr_full  String? @db.VarChar(80)
  addr_city  String? @db.VarChar(80)
  source     String? @db.VarChar(80)
  osm_id     Float?
  osm_type   String? @db.VarChar(80)
  geom       Unsupported("geometry(Point, 4326)")?

  @@map("eth_health")
}

// --------------------------------------------------------
// Ethiopian Education Facilities (Schools, Universities, etc)
// --------------------------------------------------------
model EthiopiaEducation {
  gid        Int     @id @default(autoincrement())
  name       String? @db.VarChar(131)
  name_en    String? @db.VarChar(127)
  amenity    String? @db.VarChar(80)
