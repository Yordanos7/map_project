model RoadSign {
  id        String   @id
  objectid  Int
  signType  String   @map("sign_type")
  lat       Float
  long      Float
  remark    String?
  
  // PostGIS geometry column
  geom      Unsupported("geometry(Point, 4326)")?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("road_signs")
}

// -----------------------------------------------------
// DIVA-GIS Exact Shapefile Models (Ethiopia Specific)
// These models EXACTLY match the tables generated by shp2pgsql
// when importing DIVA-GIS shapefiles (like ETH_adm.zip or ETH_rds.zip).
// -----------------------------------------------------

model EthiopiaBoundary {
  // Primary key automatically generated by shp2pgsql
  gid       Int     @id @default(autoincrement())
  
  // Standard DIVA-GIS .dbf attributes for Ethiopian Administrative Boundaries
  id_0      Int?
  iso       String? @db.VarChar(254)
  name_0    String? @db.VarChar(254)
  id_1      Int?
  name_1    String? @db.VarChar(254)
  type_1    String? @db.VarChar(254)
  engtype_1 String? @db.VarChar(254)
  nl_name_1 String? @db.VarChar(254)
  varname_1 String? @db.VarChar(254)
  
  // Exact PostGIS spatial geography column formatting for boundaries
  geom      Unsupported("geometry(MultiPolygon, 4326)")?

  @@map("eth_adm1")
}

model EthiopiaRoad {
  // Primary key automatically generated by shp2pgsql
  gid         Int     @id @default(autoincrement())
  
  // Standard DIVA-GIS .dbf attributes for Ethiopian Roads
  fnode_      Float?
  tnode_      Float?
  lpoly_      Float?
  rpoly_      Float?
  length      Float?
  eth_roads_  Float?
  eth_roads_i Float?
  fclass      Int?
  name        String? @db.VarChar(254)
  
  // Exact PostGIS spatial geography column formatting for paths
  geom        Unsupported("geometry(MultiLineString, 4326)")?

  @@map("eth_roads")
}

model WorldBoundary {
  gid       Int     @id @default(autoincrement())
  admin     String? @db.VarChar(254)
  geom      Unsupported("geometry(MultiPolygon, 4326)")?

  @@map("world_boundaries")
}
