}

// --------------------------------------------------------
// Ethiopian Land Cover (DIVA-GIS Raster grid downsampled)
// --------------------------------------------------------
model EthiopiaLandcover {
  gid         Int     @id @default(autoincrement())
  cover_class Int
  lon         Float
  lat         Float
  geom        Unsupported("geometry(Point, 4326)")?

  @@map("eth_landcover")
}

// --------------------------------------------------------
// Ethiopian Railways (DIVA-GIS Infrastructure)
// --------------------------------------------------------
model EthiopiaRailway {
  gid        Int     @id @default(autoincrement())
  f_code_des String? @db.VarChar(254)
  exs_descri String? @db.VarChar(254)
  fco_descri String? @db.VarChar(254)
  isocountry String? @db.VarChar(54)
  geom       Unsupported("geometry(MultiLineString, 4326)")?

  @@map("eth_railways")
}

// --------------------------------------------------------
// Ethiopian Energy & Telecom Infrastructure (OSM)
// --------------------------------------------------------
model EthiopiaEnergyTelecom {
  gid      Int     @id @default(autoincrement())
  name     String? @db.VarChar(254)
  power    String? @db.VarChar(80)
  voltage  String? @db.VarChar(80)
  operator String? @db.VarChar(254)
  osm_id   Float?
  geom     Unsupported("geometry(MultiLineString, 4326)")?

  @@map("eth_energy_telecom")
}
