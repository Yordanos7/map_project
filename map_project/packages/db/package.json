{
  "name": "@map_project/db",
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./*": {
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "postinstall": "node -e \"if (process.env.DATABASE_URL) { require('child_process').execSync('prisma generate', { stdio: 'inherit' }) }\"",
    "db:studio": "prisma studio",
    "db:seed": "tsx --env-file=../../apps/server/.env src/seed.ts"
  },
  "dependencies": {
    "@map_project/env": "*",
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "^7.2.0",
    "dotenv": "^17.2.2",
    "pg": "^8.17.1",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@map_project/config": "*",
    "@types/pg": "^8.16.0",
    "prisma": "^7.2.0",
    "typescript": "^5"
  }
}